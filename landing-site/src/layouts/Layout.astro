---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Jarnagoose Studios',
  description = 'Welcome to Jarnagoose Studios, we are a small collaboration of independent artists working hard to make video games worth playing!',
  ogImage = 'https://jarnagoose.com/img/oglogoicon.png',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:description" content={description} />
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Livvic:wght@400;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>

<script>
  import '../styles/global.css'
</script>