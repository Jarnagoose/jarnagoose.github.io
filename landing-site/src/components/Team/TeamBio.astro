---
import teamJ from '../../assets/img/team/team_j.png';
import teamC from '../../assets/img/team/team_c.png';
import teamS from '../../assets/img/team/team_s.png';
import teamR from '../../assets/img/team/team_r.png';
import teamB from '../../assets/img/team/team_b.png';
import teamJ2 from '../../assets/img/team/team_j2.png';

const members = [
  {
    name: 'Kyle Jarnagoose',
    role: 'CEO/Creative Director',
    image: teamJ.src,
    pronouns: 'his',
    bio: 'Once a silly goose, now the leader of a budding flock, Kyle is our game director, overseeing all aspects of Wandercap Chronicles as the originator of the concept. His list of interests, and thoughts about those interests, are longer than any mortal man can comprehend... but retro, narrative-based games come to mind as inspiration.',
    favorites: ['The Binding of Isaac', 'EarthBound', 'Resident Evil (the series)', 'Slay the Spire', 'Dark Souls'],
  },
  {
    name: 'Chaz Chester',
    role: 'Lead Digital Artist',
    image: teamC.src,
    pronouns: 'his',
    bio: "Once known for his encyclopedic knowledge of all things Super Mario, Chaz now leads our art team to bring the wonderful imaginings of the team to life. When he isn't creating pixel-perfect art, Chaz digs his teeth into collecting games one title at a time, learning all their intricacies before moving on to the next. Chaz's background as a filmmaker allows him to bring a unique perspective to the team, often incorporating unconventional techniques and workflows into his design process.",
    favorites: ['The Paper Mario Series', 'Portal 2', 'The Stanley Parable', 'Life is Strange', 'The Last of Us'],
  },
  {
    name: 'Marcus Sanchez',
    role: 'Lead Developer',
    image: teamS.src,
    pronouns: 'his',
    bio: "The man in the machine. Marcus is responsible for crafting all the systems and maintaining our game engine, taking total ownership of Wandercap Chronicles's mechanics and systems. Having played RPGs since he was just old enough to read, Marcus is overjoyed to be bringing his talents to his favorite game genre.",
    favorites: ['Final Fantasy VII', 'Final Fantasy X', 'Pokemon Platinum', 'Minecraft', 'Super Smash Bros. (the series)'],
  },
  {
    name: 'Zachary Reichel',
    role: 'Narrative Producer',
    image: teamR.src,
    pronouns: 'his',
    bio: "Writer, SFX engineer, Project Manager... Zach wears several hats to help the team. What can we say? Zach has always been a support player, stemming from his MMORPG days as healer and shot-caller. Nowadays, Zach creates all the written materials for the team, organizes their workflows, and translates the ramblings of Kyle into a workable narrative structure.",
    favorites: ['Spyro: Year of the Dragon', 'Final Fantasy (the series)', 'TES: Oblivion', 'Mabinogi', 'Kingdom Hearts II'],
  },
  {
    name: 'Chris Berry',
    role: 'Lead Concept Artist',
    image: teamB.src,
    pronouns: 'his',
    bio: "With experience in gaming and creating that started almost at birth, Chris helps to translate words into visuals, leading our concept art and environmental design efforts. His love for games that feature creative puzzles, exploration, and discovery has stoked a passion for detailed environments that bring stories to life.",
    favorites: ["The Legend of Zelda: The Wind Waker", "The Legend of Zelda: Majora's Mask", "Marvel's Spider-Man", 'Super Mario 64', 'Hades', 'Lode Runner', 'Sonic Adventure DX: Director\'s Cut'],
  },
];
---

<!-- ABOUT INTRO -->
<section class="py-12 bg-gray-700">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">Meet the Team</h1>
    <p class="text-gray-300 text-lg leading-relaxed">
      At Jarnagoose Studios, we are a passionate team of game developers,
      artists, and storytellers dedicated to creating immersive gaming
      experiences. Our diverse backgrounds and shared love for gaming
      drive us to push the boundaries of creativity and innovation.
    </p>
  </div>
</section>

<!-- TEAM MEMBERS -->
<section class="py-8 bg-gray-700">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {members.map((member, i) => (
        <div class="bg-gray-800 rounded-xl overflow-hidden shadow-lg flex flex-col">
          <!-- Member Photo -->
          <img
            src={member.image}
            alt={member.name}
            class="w-full object-cover"
          />

          <!-- Name & Role (always visible) -->
          <div class="px-5 pt-4 pb-2">
            <h3 class="text-white font-bold text-lg">{member.name}</h3>
            <p class="text-purple-400 text-sm">{member.role}</p>
          </div>

          <!-- Accordion toggle -->
          <div class="px-5 pb-4">
            <button
              class="md:hidden text-gray-400 text-sm hover:text-purple-400 transition-colors flex items-center gap-1 member-toggle"
              data-target={`member-bio-${i}`}
              aria-expanded="false"
            >
              <span class="toggle-label">Read more</span>
              <svg class="h-4 w-4 toggle-icon transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>

            <!-- Bio (collapsed on mobile, always visible on desktop) -->
            <div id={`member-bio-${i}`} class="hidden md:block mt-3 space-y-3">
              <p class="text-gray-300 text-sm leading-relaxed">{member.bio}</p>
              <div class="text-sm">
                <p class="text-white font-semibold mb-1">
                  {member.pronouns === 'her' ? 'Her' : 'His'} favorite games include:
                </p>
                <p class="text-gray-400 italic">
                  {member.favorites.join(', ')}
                </p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.member-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const targetId = btn.getAttribute('data-target');
      const bio = document.getElementById(targetId!);
      const icon = btn.querySelector('.toggle-icon') as HTMLElement;
      const label = btn.querySelector('.toggle-label') as HTMLElement;
      const isOpen = !bio?.classList.contains('hidden');

      bio?.classList.toggle('hidden');
      icon?.classList.toggle('rotate-180');
      btn.setAttribute('aria-expanded', String(!isOpen));
      if (label) label.textContent = isOpen ? 'Read more' : 'Read less';
    });
  });
</script>
