
---
import teamPlaceholder from '../../assets/img/team-placeholder.jpg';
---

<section class="py-12 bg-gray-500">
  <div class="max-w-7xl mx-auto px-4">
    <!-- Team Image -->
    <div class="rounded-lg overflow-hidden mb-4">
      <img
        src={teamPlaceholder.src}
        alt="Jarnagoose Studios Team"
        class="w-full h-auto"
      />
    </div>

    <!-- Team Info -->
    <div class="text-center">
      <h3 class="text-3xl md:text-4xl font-bold text-white mb-6">
        Jarnagoose Studios Team
      </h3>
      <a
        href="/team"
        class="inline-block px-8 py-3 bg-purple-600 hover:bg-purple-700 text-white font-semibold rounded-lg transition-colors duration-200"
      >
        Meet the Team
      </a>
    </div>
  </div>
</section>